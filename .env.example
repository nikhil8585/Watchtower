# Watchtower — Environment Configuration
# =========================================
# Copy this file to .env and fill in all values before starting.
# NEVER commit .env to version control.

# ── General ───────────────────────────────────────────────────────────────────

# Human-readable name for this Watchtower instance
WATCHTOWER_NAME=Watchtower-Production

# How often to check for surveys (seconds).
# Example: 60 = check every 1 minute
CHECK_INTERVAL=60

# ── Browser ───────────────────────────────────────────────────────────────────

# Run Chromium in headless mode (true for server/production, false for local debugging)
HEADLESS=true

# Playwright slow-motion delay in milliseconds (0 for production, 500-1000 for debugging)
SLOW_MO=0

# Default element / navigation timeout in milliseconds
DEFAULT_TIMEOUT=30000

# ── Scheduling ────────────────────────────────────────────────────────────────

# IANA timezone for the scheduler and log timestamps
# Examples: Asia/Kolkata, America/New_York, Europe/London, UTC
TIMEZONE=Asia/Kolkata

# ── Logging ───────────────────────────────────────────────────────────────────

# Minimum log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# ── TryRating credentials ─────────────────────────────────────────────────────

TRYRATING_USERNAME=your_email@example.com
TRYRATING_PASSWORD=your_tryrating_password

# ── Gmail SMTP ────────────────────────────────────────────────────────────────

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your_gmail@gmail.com

# Generate an App Password at: https://myaccount.google.com/apppasswords
# (Requires 2FA enabled on your Google account)
SMTP_APP_PASSWORD=your_16_character_app_password
